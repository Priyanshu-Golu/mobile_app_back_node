# ─── Server ──────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=5001

# ─── Database ─────────────────────────────────────────────────────────────────
MONGODB_URI=mongodb://localhost:27017/tap2help

# ─── Redis (Session & Location Cache) ────────────────────────────────────────
# Leave blank to run without Redis (cache will be disabled gracefully)
REDIS_URL=redis://localhost:6379

# ─── JWT ──────────────────────────────────────────────────────────────────────
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_REFRESH_SECRET=your-refresh-token-secret-change-this-too
JWT_EXPIRE=24h
JWT_REFRESH_EXPIRE=7d

# ─── Firebase Cloud Messaging ──────────────────────────────────────────────────
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxx@your-project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END PRIVATE KEY-----\n"

# ─── Google OAuth ─────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ─── Google Maps ──────────────────────────────────────────────────────────────
GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# ─── Email (Gmail SMTP) ────────────────────────────────────────────────────────
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your-email@gmail.com
EMAIL_PASSWORD=your-app-password
FROM_NAME=Tap2Help
FROM_EMAIL=noreply@tap2help.com

# ─── Payment — Razorpay ────────────────────────────────────────────────────────
# Get from: https://dashboard.razorpay.com/app/keys
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your-razorpay-secret
# Credit-to-INR rate (1 credit = how many INR?)
CREDIT_TO_INR_RATE=1

# ─── Payment — Stripe (international, optional) ────────────────────────────────
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxx

# ─── SMS — Twilio ──────────────────────────────────────────────────────────────
# Get from: https://console.twilio.com
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE=+1xxxxxxxxxx

# ─── Identity Verification — IDfy / Aadhaar ───────────────────────────────────
# Get from: https://developer.idfy.com
# Leave blank to use mock verification flow (OTP: 123456)
IDFY_API_KEY=your-idfy-api-key
IDFY_ACCOUNT_ID=your-idfy-account-id

# ─── Analytics — Mixpanel ─────────────────────────────────────────────────────
MIXPANEL_TOKEN=your-mixpanel-project-token

# ─── File Storage — AWS S3 / MinIO ────────────────────────────────────────────
AWS_ACCESS_KEY=your-aws-access-key
AWS_SECRET_KEY=your-aws-secret-key
AWS_REGION=ap-south-1
S3_BUCKET=tap2help-uploads
# For local MinIO: set S3_ENDPOINT
# S3_ENDPOINT=http://localhost:9000

# ─── Monitoring — Sentry ──────────────────────────────────────────────────────
SENTRY_DSN=https://xxxx@sentry.io/xxxx

# ─── Client URL ───────────────────────────────────────────────────────────────
CLIENT_URL=http://localhost:3000
# Production: CLIENT_URL=https://app.tap2help.com
